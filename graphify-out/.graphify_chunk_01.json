    {"id":"dom_capture_engine","label":"DOM Capture Engine","file_type":"rationale","source_file":"notes/masterplan.md","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null,"rationale":"Recursively walks DOM tree using getBoundingClientRect and getComputedStyle to capture position, size, and visual styles into structured JSON. Depth limited to 10 to prevent excessive recursion. Capture-phase event listeners intercept user clicks before page handlers."},
    {"id":"prompt_builder","label":"Prompt Builder","file_type":"rationale","source_file":"notes/masterplan.md","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null,"rationale":"Converts captured DOM JSON into a structured, copy-ready prompt using pure JavaScript template logic. No AI API required for v1.0 to ensure offline capability, zero backend dependency, and deterministic fast output."},
    {"id":"zero_backend_architecture","label":"Zero Backend Architecture","file_type":"rationale","source_file":"notes/masterplan.md","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null,"rationale":"Extension operates entirely client-side using chrome.storage.local. No external servers, no API keys needed in v1.0. Faster to ship, fully private, works offline."},
    {"id":"local_storage_only","label":"Local Storage Only","file_type":"rationale","source_file":"notes/masterplan.md","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null,"rationale":"Captured DOM data is stored temporarily in chrome.storage.local. It never leaves the device, is overwritten on each new capture, and is deleted when the extension is uninstalled."},
    {"id":"manifest_v3","label":"Manifest V3","file_type":"rationale","source_file":"notes/masterplan.md","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null,"rationale":"Required by Chrome for all new extensions. Uses a service worker (background.js) instead of a persistent background page. CSP compliant with no inline event handlers."},
    {"id":"vibe_coding_prompts","label":"Vibe Coding Prompt Generation","file_type":"rationale","source_file":"notes/masterplan.md","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null,"rationale":"Output formats include HTML/CSS (precise, no frameworks), React + Tailwind (arbitrary values), and v0/Bolt/Lovable (natural language, descriptive). Designed for AI builder tools."},
    {"id":"color_parser","label":"Complete Color Parser","file_type":"rationale","source_file":"CODE_FIXES_SOLUTIONS.md","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null,"rationale":"Original parseColor only handled rgb/rgba. Fixed version adds hex parsing (3 and 6 digit), CSS keyword lookup (transparent, white, black, red, green, blue), input type guards, and safe fallback to null for unhandled values like currentColor and inherit."},
    {"id":"input_validation","label":"Input Validation in buildPrompt","file_type":"rationale","source_file":"CODE_FIXES_SOLUTIONS.md","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null,"rationale":"Added object-type and array checks for capturedJSON, a whitelisted VALID_FORMATS array, and a top-level try-catch to prevent silent crashes and return meaningful error messages."},
    {"id":"dom_null_checks","label":"DOM Element Null Checks","file_type":"rationale","source_file":"CODE_FIXES_SOLUTIONS.md","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null,"rationale":"Replaced bare document.getElementById calls with a getRequiredElement helper that throws descriptive errors if any required popup DOM element is missing, preventing silent initialization failures."},
    {"id":"message_error_handling","label":"Message Error Handling","file_type":"rationale","source_file":"CODE_FIXES_SOLUTIONS.md","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null,"rationale":"Replaced Promise.catch(()=>{}) with callback-style sendMessage that checks chrome.runtime.lastError. Prevents unhandled rejections when popup is not open and surfaces debug info."},
    {"id":"tab_switch_race_condition","label":"Tab Switch Race Condition Fix","file_type":"rationale","source_file":"CODE_FIXES_SOLUTIONS.md","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null,"rationale":"Added early returns for null activeTabId and same-tab switches. Stores oldTabId before nulling state so sendMessage failure on a dead tab is handled gracefully with debug logging."},
    {"id":"event_listener_cleanup","label":"Event Listener Cleanup","file_type":"rationale","source_file":"CODE_FIXES_SOLUTIONS.md","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null,"rationale":"Added captureMode guard to activate() and deactivate() to prevent duplicate listener registration on SPAs. All four capture-phase listeners are explicitly removed on deactivation to avoid memory leaks."},
    {"id":"background_resolution","label":"Background Color Resolution","file_type":"rationale","source_file":"CODE_FIXES_SOLUTIONS.md","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null,"rationale":"Added maxDepth guard (20), ELEMENT_NODE check, and fallback to document.documentElement background before hardcoded white. Prevents infinite recursion and respects actual page background."},
    {"id":"text_truncation","label":"Better Text Truncation","file_type":"rationale","source_file":"CODE_FIXES_SOLUTIONS.md","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null,"rationale":"Replaced hardcoded slice(0,200) with a truncateText helper that finds the last space before the limit and appends an ellipsis, preventing mid-word cuts and garbled prompt output."},
    {"id":"svg_error_handling","label":"SVG Error Handling","file_type":"rationale","source_file":"CODE_FIXES_SOLUTIONS.md","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null,"rationale":"Wrapped SVG outerHTML access in a try-catch with type and length validation. Truncates oversized SVGs to 5000 chars with an inline comment, preventing crashes on malformed or huge inline SVGs."},
    {"id":"format_validation","label":"Format Validation","file_type":"rationale","source_file":"CODE_FIXES_SOLUTIONS.md","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null,"rationale":"Added a VALID_FORMATS whitelist and explicit check against btn.dataset.format before updating state. Prevents XSS-like injection via manipulated data attributes and skips redundant re-renders."},
    {"id":"design_tokens","label":"Design Tokens Extraction","file_type":"rationale","source_file":"README.md","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null,"rationale":"Colors, fonts, spacing, radii, and shadows are deduplicated into a token table within the generated prompt to give AI builders a consolidated reference and maintain consistency."}
  ],

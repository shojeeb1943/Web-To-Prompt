{
  "manifest_version": 3,
  "name": "Web To Prompt",
  "version": "1.0.0",
  "description": "Hover over any website section, click it, and instantly get a vibe coding prompt to rebuild it with AI.",
  "permissions": ["activeTab", "scripting", "clipboardWrite", "storage"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "commands": {
    "activate_capture": {
      "suggested_key": {
        "default": "Alt+Shift+W"
      },
      "description": "Activate capture mode"
    }
  }
}
